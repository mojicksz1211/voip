# PBX server
PORT=3000

# LiveKit (defaults match livekit.yaml dev keys)
LIVEKIT_HOST=http://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=hotel-local-voip-livekit-dev-secret-32
# Optional override when auto-detection is wrong (e.g. tablet on LAN)
# LIVEKIT_WS_URL=ws://192.168.110.50:7880

# Front desk dev — proxy target (default 127.0.0.1:3000). Vite binds 0.0.0.0:5174 for LAN access.
# Other PCs: http://<this-pc-lan-ip>:5174/  (allow Windows Firewall: 5174, 3000, 7880)
# VITE_PBX_PROXY_TARGET=http://127.0.0.1:3000
