{
  "name": "@hotel-voip/pbx-server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "esbuild src/server.ts --bundle --platform=node --format=esm --packages=external --sourcemap --outfile=dist/server.js",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@hotel-voip/shared": "*",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "livekit-server-sdk": "^2.13.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
